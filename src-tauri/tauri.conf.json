{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "YAMV",
  "version": "0.9.1",
  "identifier": "de.martinemmert.projects.yamv",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "YAMV",
        "width": 800,
        "height": 900,
        "minWidth": 400,
        "minHeight": 300,
        "resizable": true,
        "center": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/martinemmert/yet-another-markdown-viewer/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM1MzBDRDRCMENBODMyQ0IKUldUTE1xZ01TODB3eFdvL3hYdVU4Nk92cHI3U1M5d3JoVlh6KytXa2dFdk95aUltSW5UbnJQbTIK"
    },
    "deep-link": {
      "desktop": {
        "schemes": ["yamv"]
      }
    },
    "cli": {
      "description": "Yet Another Markdown Viewer",
      "args": [
        {
          "name": "file",
          "index": 1,
          "takesValue": true,
          "required": false,
          "description": "Markdown file to open"
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "mdx", "mdown", "mkd"],
        "mimeType": "text/markdown",
        "description": "Markdown Document",
        "role": "Viewer"
      }
    ]
  }
}
